# Runtime
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8083
DASHBOARD_BASE_URL=https://cloudways-monitor.example.com
SQLITE_PATH=/data/cloudways-monitor.sqlite3
POLL_INTERVAL_SECONDS=60
STALE_AFTER_SECONDS=600
RETENTION_DAYS=30

# Cloudways API
CLOUDWAYS_EMAIL=you@example.com
CLOUDWAYS_API_KEY=replace-with-cloudways-api-key
CLOUDWAYS_API_BASE_URL=https://api.cloudways.com/api/v2
CLOUDWAYS_TASK_POLLING_ENABLED=true
CLOUDWAYS_TASK_POLL_ATTEMPTS=1
CLOUDWAYS_TASK_POLL_INTERVAL_SECONDS=0
CLOUDWAYS_MONITOR_GRAPH_DURATION=1 Hour
CLOUDWAYS_MONITOR_GRAPH_TIMEZONE=UTC
CLOUDWAYS_APP_TRAFFIC_POLLING_ENABLED=true
CLOUDWAYS_APP_TRAFFIC_DURATION=1h

# Optional comma-separated Cloudways IDs. Leave blank to monitor all discovered resources.
MONITORED_SERVER_IDS=
MONITORED_APP_IDS=

# Single-user app-level auth
DASHBOARD_USERNAME=admin
# Store a password hash, not a plaintext password.
# Format: pbkdf2_sha256:iterations:salt:base64url-hash
DASHBOARD_PASSWORD_HASH=pbkdf2_sha256:100000:replace-with-salt:replace-with-base64url-hash
SESSION_SECRET=replace-with-random-session-secret
SESSION_COOKIE_SECURE=true

# Telegram notifications
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_CHAT_ID=replace-with-chat-id
TELEGRAM_ENABLED=true

# Alert defaults
CPU_WARNING_PERCENT=80
CPU_CRITICAL_PERCENT=95
RAM_WARNING_PERCENT=80
RAM_CRITICAL_PERCENT=95
DISK_WARNING_PERCENT=80
DISK_CRITICAL_PERCENT=90
ALERT_CONSECUTIVE_POLLS=3
ALERT_COOLDOWN_SECONDS=1800
